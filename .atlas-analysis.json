  "keyFeatures": [
    "Daemonless architecture — no background service required",
    "Rootless containers — run containers without root privileges",
    "Docker-compatible CLI — drop-in alias for Docker commands",
    "Native pod management — group containers sharing resources",
    "Quadlet/systemd integration — declarative container management via unit files",
    "REST API — Docker-compatible and Podman-native HTTP APIs",
    "Cross-platform — runs on Linux natively, macOS and Windows via virtual machine",
    "OCI-compliant — supports OCI and Docker image formats",
    "Kubernetes integration — generate and play Kubernetes YAML",
    "Multi-arch builds via podman farm — build images for multiple architectures"
  ],
  "publicApiSurface": [
